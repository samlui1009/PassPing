{
  "manifest_version": 3,
  "name": "PassPing",
  "version": "1.0.0",
  "description": "Passping is a Google Chrome extension that helps remind post-secondary students to reload next months' U-Pass. Never forget your reload again!",
  "action": {
    "default_popup": "index.html",
    "default_title": "PassPing Reminder",
    "default_icon": {
      "16": "icons/bus_notification.png",
      "32": "icons/bus_notification.png",
      "48": "icons/bus_notification.png",
      "128": "icons/bus_notification.png"
    }
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
